# Copy this file to .env for local development.
# Values are fictitious development placeholders. Do not commit real secrets.

NODE_ENV=development

POSTGRES_DB=solverfin
POSTGRES_USER=solverfin
POSTGRES_PASSWORD=solverfin_dev_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://solverfin:solverfin_dev_password@localhost:5432/solverfin?schema=public

# Optional local session duration for the initial auth layer.
AUTH_SESSION_TTL_MINUTES=60

# Optional inactivity timeout for persisted application sessions.
AUTH_SESSION_IDLE_TIMEOUT_MINUTES=30

# Demo auth is local-only by default. Keep false unless running an explicit non-production demo.
AUTH_ALLOW_DEMO=false

# Managed identity-provider page used by the "Esqueci minha senha" action.
AUTH_PASSWORD_RESET_URL=https://identity.example.invalid/solverfin/reset-password

# Comma-separated list of emails allowed to access global Admin features.
# Leave empty in local environments that do not need Admin access; empty config fails closed.
SOLVERFIN_MASTER_EMAILS=master@solverfin.example.invalid

# Daily CDI import and account-remuneration processing.
# Disabled by default; enable only in one API scheduler instance per environment.
ACCOUNT_REMUNERATION_DAILY_ENABLED=false
# UTC hour from 0 to 23. 10 UTC corresponds to 07:00 in Sao Paulo during standard time.
ACCOUNT_REMUNERATION_DAILY_HOUR_UTC=10
# Optional override used by tests or controlled provider migrations.
BCB_SGS_CDI_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs.12/dados

# Cloudflare R2 settings for Admin institution logo uploads. Keep real values only in protected environments.
R2_ACCOUNT_ID=00000000000000000000000000000000
R2_ACCESS_KEY_ID=dev-r2-access-key
R2_SECRET_ACCESS_KEY=dev-r2-secret-key
R2_BUCKET_NAME=solverfin-assets
R2_PUBLIC_BASE_URL=https://assets.example.invalid
R2_REGION=auto
INSTITUTION_LOGO_MAX_BYTES=2097152

# Productive authentication uses a managed OIDC/OAuth2 provider.
# Keep these as fictitious development placeholders here; configure real values only in protected environments.
OIDC_ISSUER_URL=https://identity.example.invalid/solverfin
OIDC_AUDIENCE=solverfin-api
OIDC_JWKS_URI=https://identity.example.invalid/solverfin/.well-known/jwks.json
