{
  "name": "@solverfin/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aplicacao web/PWA mobile-first do SolverFin.",
  "scripts": {
    "dev": "echo \"@solverfin/web: dev ainda sera configurado na issue de frontend/bootstrap\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "rm -rf ../../.tmp-tests/web && tsc -p tsconfig.test.json && node ../../.tmp-tests/web/pwa/manifest.test.js && node ../../.tmp-tests/web/inbox/share-target.test.js",
    "build": "tsc --noEmit",
    "format:diagnose": "prettier ../../apps/web/src/inbox/share-target.test.ts ../../apps/web/src/inbox/share-target.ts ../../apps/web/src/pwa/manifest.test.ts ../../apps/web/src/pwa/manifest.ts --write && git diff -- ../../apps/web/src/inbox/share-target.test.ts ../../apps/web/src/inbox/share-target.ts ../../apps/web/src/pwa/manifest.test.ts ../../apps/web/src/pwa/manifest.ts && git diff --exit-code -- ../../apps/web/src/inbox/share-target.test.ts ../../apps/web/src/inbox/share-target.ts ../../apps/web/src/pwa/manifest.test.ts ../../apps/web/src/pwa/manifest.ts"
  }
}
