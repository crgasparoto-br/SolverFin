{
  "name": "solverfin",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "solverfin",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/api": {
      "name": "@solverfin/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@solverfin/web",
      "version": "0.1.0"
    },
    "node_modules/@solverfin/ai": {
      "resolved": "packages/ai",
      "link": true
    },
    "node_modules/@solverfin/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@solverfin/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@solverfin/domain": {
      "resolved": "packages/domain",
      "link": true
    },
    "node_modules/@solverfin/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@solverfin/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/ai": {
      "name": "@solverfin/ai",
      "version": "0.1.0"
    },
    "packages/config": {
      "name": "@solverfin/config",
      "version": "0.1.0"
    },
    "packages/domain": {
      "name": "@solverfin/domain",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@solverfin/shared",
      "version": "0.1.0"
    }
  }
}
