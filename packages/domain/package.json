  "private": true,
  "type": "module",
  "description": "Regras e entidades do dominio financeiro, isoladas de infraestrutura.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
